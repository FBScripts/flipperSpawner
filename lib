local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Library = {}

local TWEEN_FAST = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_SMOOTH = TweenInfo.new(0.6, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)

-- Генератор волнистого текста
local function CreateWavyText(parent, textStr)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 1, 0)
	container.BackgroundTransparency = 1
	container.Parent = parent

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Left -- ФИКС: Текст теперь не выпирает
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Padding = UDim.new(0, 1)
	layout.Parent = container

	local letters = {}
	for i = 1, #textStr do
		local char = textStr:sub(i, i)
		local letter = Instance.new("TextLabel")
		letter.Text = char
		letter.Size = UDim2.new(0, char == " " and 8 or 12, 1, 0)
		letter.BackgroundTransparency = 1
		letter.Font = Enum.Font.Code
		letter.TextColor3 = Color3.fromRGB(255, 255, 255)
		letter.TextSize = 16
		letter.Parent = container

		local gradient = Instance.new("UIGradient")
		gradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 170, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
		})
		gradient.Rotation = 45
		gradient.Parent = letter

		table.insert(letters, {Label = letter, Gradient = gradient, Index = i})
	end

	RunService.RenderStepped:Connect(function()
		local timeNow = tick()
		for _, data in ipairs(letters) do
			data.Label.Position = UDim2.new(0, 0, 0, math.sin(timeNow * 4 + data.Index * 0.5) * 3)
			data.Gradient.Offset = Vector2.new(math.sin(timeNow * 2 + data.Index * 0.2), 0)
		end
	end)
end

function Library:CreateWindow(options)
	local WindowConfig = {}
	options = options or {}
	local titleText = options.Title or "Flipper's Spawner"
	local loadIconId = options.Icon or "rbxassetid://3926305904"

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "OldSchoolLib"
	ScreenGui.ResetOnSpawn = false
	pcall(function() ScreenGui.Parent = CoreGui end)
	if not ScreenGui.Parent then ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end

	-- Главный фрейм
	local MainFrame = Instance.new("Frame")
	MainFrame.Size = UDim2.new(0, 100, 0, 100)
	MainFrame.Position = UDim2.new(0.5, -50, 0.5, -50)
	MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	MainFrame.BorderSizePixel = 0
	MainFrame.ClipsDescendants = true -- ФИКС: Скрывает вылеты при скруглении и сворачивании
	MainFrame.Parent = ScreenGui
	
	local MainCorner = Instance.new("UICorner")
	MainCorner.CornerRadius = UDim.new(0, 8)
	MainCorner.Parent = MainFrame

	-- Иконка загрузки (по центру)
	local LoadingIcon = Instance.new("ImageLabel")
	LoadingIcon.Size = UDim2.new(0, 40, 0, 40)
	LoadingIcon.Position = UDim2.new(0.5, -20, 0.5, -20)
	LoadingIcon.BackgroundTransparency = 1
	LoadingIcon.Image = loadIconId
	LoadingIcon.ImageRectOffset = Vector2.new(964, 324)
	LoadingIcon.ImageRectSize = Vector2.new(36, 36)
	LoadingIcon.ImageColor3 = Color3.fromRGB(255, 170, 0)
	LoadingIcon.Parent = MainFrame

	local spin = TweenService:Create(LoadingIcon, TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), {Rotation = 360})
	spin:Play()
	task.wait(1)

	spin:Cancel()
	TweenService:Create(LoadingIcon, TWEEN_FAST, {ImageTransparency = 1, Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
	task.wait(0.2)

	local expandTween = TweenService:Create(MainFrame, TWEEN_SMOOTH, {
		Size = UDim2.new(0, 750, 0, 450),
		Position = UDim2.new(0.5, -375, 0.5, -225)
	})
	expandTween:Play()
	expandTween.Completed:Wait()

	-- Хедер
	local Header = Instance.new("Frame")
	Header.Size = UDim2.new(1, 0, 0, 40)
	Header.BackgroundTransparency = 1
	Header.Active = true
	Header.Parent = MainFrame

	-- ФИКС: Иконка в хедере
	local HeaderIcon = Instance.new("ImageLabel")
	HeaderIcon.Size = UDim2.new(0, 20, 0, 20)
	HeaderIcon.Position = UDim2.new(0, 10, 0.5, -10)
	HeaderIcon.BackgroundTransparency = 1
	HeaderIcon.Image = loadIconId
	HeaderIcon.ImageRectOffset = Vector2.new(964, 324)
	HeaderIcon.ImageRectSize = Vector2.new(36, 36)
	HeaderIcon.ImageColor3 = Color3.fromRGB(255, 170, 0)
	HeaderIcon.Parent = Header

	local TitleContainer = Instance.new("Frame")
	TitleContainer.Size = UDim2.new(0, 300, 1, 0)
	TitleContainer.Position = UDim2.new(0, 40, 0, 0)
	TitleContainer.BackgroundTransparency = 1
	TitleContainer.Parent = Header
	CreateWavyText(TitleContainer, titleText)

	-- ФИКС: DRAGGABLE
	local dragging, dragInput, dragStart, startPos
	Header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = MainFrame.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)
	RunService.RenderStepped:Connect(function()
		if dragging and dragInput then
			local delta = dragInput.Position - dragStart
			MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)

	local Controls = Instance.new("Frame")
	Controls.Size = UDim2.new(0, 60, 1, 0)
	Controls.Position = UDim2.new(1, -60, 0, 0)
	Controls.BackgroundTransparency = 1
	Controls.Parent = Header

	local MinBtn = Instance.new("TextButton", Controls)
	MinBtn.Size = UDim2.new(0, 14, 0, 14)
	MinBtn.Position = UDim2.new(0, 0, 0.5, -7)
	MinBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
	MinBtn.Text = ""
	Instance.new("UICorner", MinBtn).CornerRadius = UDim.new(1, 0)

	local CloseBtn = Instance.new("TextButton", Controls)
	CloseBtn.Size = UDim2.new(0, 14, 0, 14)
	CloseBtn.Position = UDim2.new(0, 22, 0.5, -7)
	CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
	CloseBtn.Text = ""
	Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(1, 0)

	-- ФИКС: Сворачивание
	local isMinimized = false
	MinBtn.MouseButton1Click:Connect(function()
		isMinimized = not isMinimized
		if isMinimized then
			TweenService:Create(MainFrame, TWEEN_FAST, {Size = UDim2.new(0, 750, 0, 40)}):Play()
		else
			TweenService:Create(MainFrame, TWEEN_FAST, {Size = UDim2.new(0, 750, 0, 450)}):Play()
		end
	end)

	CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

	local Separator = Instance.new("Frame", Header)
	Separator.Size = UDim2.new(1, 0, 0, 2)
	Separator.Position = UDim2.new(0, 0, 1, 0)
	Separator.BorderSizePixel = 0
	local SepGradient = Instance.new("UIGradient", Separator)
	SepGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 170, 0)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 100, 0))
	})

	-- Панели
	local Sidebar = Instance.new("Frame", MainFrame)
	Sidebar.Size = UDim2.new(0, 130, 1, -42)
	Sidebar.Position = UDim2.new(0, 0, 0, 42)
	Sidebar.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
	Sidebar.BorderSizePixel = 0
	
	local SidebarLayout = Instance.new("UIListLayout", Sidebar)
	SidebarLayout.Padding = UDim.new(0, 5)

	local ContentScroll = Instance.new("ScrollingFrame", MainFrame)
	ContentScroll.Size = UDim2.new(1, -310, 1, -42)
	ContentScroll.Position = UDim2.new(0, 130, 0, 42)
	ContentScroll.BackgroundTransparency = 1
	ContentScroll.ScrollBarThickness = 2
	ContentScroll.ScrollBarImageColor3 = Color3.fromRGB(255, 170, 0)
	ContentScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	ContentScroll.CanvasSize = UDim2.new(0, 0, 0, 0)

	local GridLayout = Instance.new("UIGridLayout", ContentScroll)
	GridLayout.CellSize = UDim2.new(0, 95, 0, 115)
	GridLayout.CellPadding = UDim2.new(0, 10, 0, 10)
	GridLayout.SortOrder = Enum.SortOrder.LayoutOrder

	local UIPadding = Instance.new("UIPadding", ContentScroll)
	UIPadding.PaddingTop = UDim.new(0, 15)
	UIPadding.PaddingLeft = UDim.new(0, 15)

	local PropertiesPanel = Instance.new("Frame", MainFrame)
	PropertiesPanel.Size = UDim2.new(0, 180, 1, -42)
	PropertiesPanel.Position = UDim2.new(1, -180, 0, 42)
	PropertiesPanel.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
	PropertiesPanel.BorderSizePixel = 0

	local PropTitle = Instance.new("TextLabel", PropertiesPanel)
	PropTitle.Size = UDim2.new(1, 0, 0, 30)
	PropTitle.Position = UDim2.new(0, 10, 0, 0)
	PropTitle.BackgroundTransparency = 1
	PropTitle.Text = "/properties"
	PropTitle.TextColor3 = Color3.fromRGB(150, 150, 150)
	PropTitle.Font = Enum.Font.Code
	PropTitle.TextXAlignment = Enum.TextXAlignment.Left

	-- ФИКС: Вкладки
	local function CreateTab(name, isActive)
		local TabBtn = Instance.new("TextButton", Sidebar)
		TabBtn.Size = UDim2.new(1, 0, 0, 35)
		TabBtn.BackgroundTransparency = isActive and 0 or 1
		TabBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		TabBtn.Text = "  " .. name
		TabBtn.TextColor3 = isActive and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(150, 150, 150)
		TabBtn.Font = Enum.Font.Code
		TabBtn.TextXAlignment = Enum.TextXAlignment.Left
		
		-- Индикатор активной вкладки
		local Indicator = Instance.new("Frame", TabBtn)
		Indicator.Size = UDim2.new(0, 3, 1, 0)
		Indicator.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
		Indicator.BorderSizePixel = 0
		Indicator.Visible = isActive
		
		return TabBtn, Indicator
	end

	local MainTabBtn, MainInd = CreateTab("Main", true)
	local SettingsTabBtn, SetInd = CreateTab("Settings", false)

	MainTabBtn.MouseButton1Click:Connect(function()
		MainTabBtn.BackgroundTransparency = 0; MainTabBtn.TextColor3 = Color3.fromRGB(255, 170, 0); MainInd.Visible = true
		SettingsTabBtn.BackgroundTransparency = 1; SettingsTabBtn.TextColor3 = Color3.fromRGB(150, 150, 150); SetInd.Visible = false
		ContentScroll.Visible = true
	end)

	SettingsTabBtn.MouseButton1Click:Connect(function()
		SettingsTabBtn.BackgroundTransparency = 0; SettingsTabBtn.TextColor3 = Color3.fromRGB(255, 170, 0); SetInd.Visible = true
		MainTabBtn.BackgroundTransparency = 1; MainTabBtn.TextColor3 = Color3.fromRGB(150, 150, 150); MainInd.Visible = false
		ContentScroll.Visible = false
	end)

	-- Создание карточки
	function WindowConfig:CreateItem(name, imageId)
		local Card = Instance.new("TextButton")
		Card.Name = name
		Card.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		Card.Text = ""
		Card.AutoButtonColor = false
		Card.Parent = ContentScroll
		Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 6)

		local UIScale = Instance.new("UIScale", Card)

		local TopLine = Instance.new("Frame", Card)
		TopLine.Size = UDim2.new(1, 0, 0, 2)
		TopLine.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TopLine.BorderSizePixel = 0
		local LineGrad = Instance.new("UIGradient", TopLine)
		LineGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 170, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 80, 0))
		})

		local PetImage = Instance.new("ImageLabel", Card)
		PetImage.Size = UDim2.new(0.8, 0, 0.6, 0)
		PetImage.Position = UDim2.new(0.1, 0, 0.1, 0)
		PetImage.BackgroundTransparency = 1
		PetImage.ScaleType = Enum.ScaleType.Fit
		PetImage.Image = imageId or ""

		local PetName = Instance.new("TextLabel", Card)
		PetName.Size = UDim2.new(1, -10, 0, 20)
		PetName.Position = UDim2.new(0, 5, 1, -25)
		PetName.BackgroundTransparency = 1
		PetName.Text = name
		PetName.TextColor3 = Color3.fromRGB(200, 200, 200)
		PetName.Font = Enum.Font.Code
		PetName.TextSize = 12
		PetName.TextTruncate = Enum.TextTruncate.AtEnd

		Card.MouseEnter:Connect(function()
			TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.05}):Play()
			Card.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
		end)
		Card.MouseLeave:Connect(function()
			TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.0}):Play()
			Card.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		end)

		return Card
	end

	return WindowConfig
end

return Library
