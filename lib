			AppState[key] = not AppState[key]
			Btn.BackgroundColor3 = AppState[key] and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(35, 35, 40)
			Btn.TextColor3 = AppState[key] and Color3.fromRGB(25, 25, 30) or Color3.fromRGB(150, 150, 150)
			
			-- Логика блока Age при M
			if key == "M" and AgeInputBox then
				if AppState.M then
					AgeInputBox.Text = "6"
					AgeInputBox.TextEditable = false
					AgeInputBox.TextColor3 = Color3.fromRGB(100, 100, 100)
					AppState.Age = "6"
				else
					AgeInputBox.TextEditable = true
					AgeInputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				end
			end
		end)
	end
