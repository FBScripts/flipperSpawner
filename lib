local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Library = {}

local TWEEN_FAST = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_SMOOTH = TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)

function Library:CreateWindow(options)
	options = options or {}
	local titleText = options.Title or "Flipper's Spawner"
	
	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "OldSchoolLib"
	ScreenGui.ResetOnSpawn = false
	pcall(function() ScreenGui.Parent = CoreGui end)
	if not ScreenGui.Parent then ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end

	-- Свернутый текст (появляется при сворачивании)
	local MinimizedText = Instance.new("TextButton")
	MinimizedText.Size = UDim2.new(0, 200, 0, 30)
	MinimizedText.Position = UDim2.new(0.5, -100, 0, 10)
	MinimizedText.BackgroundTransparency = 1
	MinimizedText.Font = Enum.Font.Code
	MinimizedText.Text = titleText
	MinimizedText.TextColor3 = Color3.fromRGB(255, 170, 0)
	MinimizedText.TextSize = 18
	MinimizedText.Visible = false
	MinimizedText.Parent = ScreenGui

	local MainFrame = Instance.new("Frame")
	MainFrame.Size = UDim2.new(0, 750, 0, 450)
	MainFrame.Position = UDim2.new(0.5, -375, 0.5, -225)
	MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	MainFrame.BorderSizePixel = 0
	MainFrame.ClipsDescendants = true
	MainFrame.Parent = ScreenGui
	Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

	-- Логика сворачивания
	MinimizedText.MouseButton1Click:Connect(function()
		MinimizedText.Visible = false
		MainFrame.Visible = true
		MainFrame.Size = UDim2.new(0, 750, 0, 0)
		TweenService:Create(MainFrame, TWEEN_SMOOTH, {Size = UDim2.new(0, 750, 0, 450)}):Play()
	end)

	local Header = Instance.new("Frame")
	Header.Size = UDim2.new(1, 0, 0, 40)
	Header.BackgroundTransparency = 1
	Header.Active = true
	Header.Parent = MainFrame

	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(0, 300, 1, 0)
	Title.Position = UDim2.new(0, 15, 0, 0)
	Title.BackgroundTransparency = 1
	Title.Text = titleText
	Title.TextColor3 = Color3.fromRGB(255, 255, 255)
	Title.Font = Enum.Font.Code
	Title.TextSize = 16
	Title.TextXAlignment = Enum.TextXAlignment.Left
	Title.Parent = Header

	-- Draggable
	local dragging, dragInput, dragStart, startPos
	Header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true; dragStart = input.Position; startPos = MainFrame.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
	end)
	RunService.RenderStepped:Connect(function()
		if dragging and dragInput then
			local delta = dragInput.Position - dragStart
			MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)

	-- Кнопки хедера
	local Controls = Instance.new("Frame", Header)
	Controls.Size = UDim2.new(0, 60, 1, 0)
	Controls.Position = UDim2.new(1, -60, 0, 0)
	Controls.BackgroundTransparency = 1

	local MinBtn = Instance.new("TextButton", Controls)
	MinBtn.Size = UDim2.new(0, 14, 0, 14)
	MinBtn.Position = UDim2.new(0, 0, 0.5, -7)
	MinBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
	MinBtn.Text = ""
	Instance.new("UICorner", MinBtn).CornerRadius = UDim.new(1, 0)

	local CloseBtn = Instance.new("TextButton", Controls)
	CloseBtn.Size = UDim2.new(0, 14, 0, 14)
	CloseBtn.Position = UDim2.new(0, 22, 0.5, -7)
	CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
	CloseBtn.Text = ""
	Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(1, 0)

	MinBtn.MouseButton1Click:Connect(function()
		local tw = TweenService:Create(MainFrame, TWEEN_FAST, {Size = UDim2.new(0, 750, 0, 0)})
		tw:Play()
		tw.Completed:Wait()
		MainFrame.Visible = false
		MinimizedText.Visible = true
	end)

	CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

	local Separator = Instance.new("Frame", Header)
	Separator.Size = UDim2.new(1, 0, 0, 2)
	Separator.Position = UDim2.new(0, 0, 1, 0)
	Separator.BorderSizePixel = 0
	local SepGradient = Instance.new("UIGradient", Separator)
	SepGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 170, 0)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 100, 0))
	})

	-- Вкладки (Иконки слева)
	local Sidebar = Instance.new("Frame", MainFrame)
	Sidebar.Size = UDim2.new(0, 50, 1, -42)
	Sidebar.Position = UDim2.new(0, 0, 0, 42)
	Sidebar.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
	Sidebar.BorderSizePixel = 0

	local SidebarLayout = Instance.new("UIListLayout", Sidebar)
	SidebarLayout.Padding = UDim.new(0, 10)
	SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 10)

	local function CreateIconTab(iconId, isActive)
		local Btn = Instance.new("TextButton", Sidebar)
		Btn.Size = UDim2.new(0, 30, 0, 30)
		Btn.BackgroundTransparency = 1
		Btn.Text = ""
		
		local Icon = Instance.new("ImageLabel", Btn)
		Icon.Size = UDim2.new(1, 0, 1, 0)
		Icon.BackgroundTransparency = 1
		Icon.Image = iconId
		Icon.ImageColor3 = isActive and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(150, 150, 150)
		
		return Btn, Icon
	end

	-- Иконки: Домик и Шестеренка (используем стандартные roblox asset id)
	local MainTabBtn, MainIcon = CreateIconTab("rbxassetid://6031094678", true)
	local SettingsTabBtn, SetIcon = CreateIconTab("rbxassetid://6031075976", false)

	-- Центральная часть (Сетка + Поиск)
	local CenterArea = Instance.new("Frame", MainFrame)
	CenterArea.Size = UDim2.new(1, -270, 1, -42) -- 750 - 50(left) - 220(right)
	CenterArea.Position = UDim2.new(0, 50, 0, 42)
	CenterArea.BackgroundTransparency = 1

	local SearchBox = Instance.new("TextBox", CenterArea)
	SearchBox.Size = UDim2.new(1, -20, 0, 30)
	SearchBox.Position = UDim2.new(0, 10, 0, 10)
	SearchBox.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
	SearchBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	SearchBox.Font = Enum.Font.Code
	SearchBox.TextSize = 14
	SearchBox.PlaceholderText = " Search pets..."
	SearchBox.Text = ""
	SearchBox.TextXAlignment = Enum.TextXAlignment.Left
	Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0, 6)

	local ContentScroll = Instance.new("ScrollingFrame", CenterArea)
	ContentScroll.Size = UDim2.new(1, 0, 1, -50)
	ContentScroll.Position = UDim2.new(0, 0, 0, 50)
	ContentScroll.BackgroundTransparency = 1
	ContentScroll.ScrollBarThickness = 2
	ContentScroll.ScrollBarImageColor3 = Color3.fromRGB(255, 170, 0)
	ContentScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	ContentScroll.CanvasSize = UDim2.new(0, 0, 0, 0)

	local GridLayout = Instance.new("UIGridLayout", ContentScroll)
	GridLayout.CellSize = UDim2.new(0, 100, 0, 120)
	GridLayout.CellPadding = UDim2.new(0, 10, 0, 10)
	GridLayout.SortOrder = Enum.SortOrder.LayoutOrder

	local UIPadding = Instance.new("UIPadding", ContentScroll)
	UIPadding.PaddingTop = UDim.new(0, 5)
	UIPadding.PaddingLeft = UDim.new(0, 10)

	-- Правая панель (Properties)
	local PropertiesPanel = Instance.new("Frame", MainFrame)
	PropertiesPanel.Size = UDim2.new(0, 220, 1, -42)
	PropertiesPanel.Position = UDim2.new(1, -220, 0, 42)
	PropertiesPanel.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
	PropertiesPanel.BorderSizePixel = 0

	local PropTitle = Instance.new("TextLabel", PropertiesPanel)
	PropTitle.Size = UDim2.new(1, 0, 0, 30)
	PropTitle.Position = UDim2.new(0, 15, 0, 5)
	PropTitle.BackgroundTransparency = 1
	PropTitle.Text = "/properties"
	PropTitle.TextColor3 = Color3.fromRGB(150, 150, 150)
	PropTitle.Font = Enum.Font.Code
	PropTitle.TextXAlignment = Enum.TextXAlignment.Left

	-- Состояние для бекенда
	local AppState = {
		SelectedPetId = nil,
		M = false, N = false, F = false, R = false,
		RPName = "", Age = "6", Friendship = "0"
	}

	-- Кнопки зелий
	local PotionsFrame = Instance.new("Frame", PropertiesPanel)
	PotionsFrame.Size = UDim2.new(1, -30, 0, 30)
	PotionsFrame.Position = UDim2.new(0, 15, 0, 45)
	PotionsFrame.BackgroundTransparency = 1

	local PotionLayout = Instance.new("UIListLayout", PotionsFrame)
	PotionLayout.FillDirection = Enum.FillDirection.Horizontal
	PotionLayout.Padding = UDim.new(0, 5)

	local function CreatePotionBtn(name, key)
		local Btn = Instance.new("TextButton", PotionsFrame)
		Btn.Size = UDim2.new(0, 40, 1, 0)
		Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		Btn.Text = name
		Btn.TextColor3 = Color3.fromRGB(150, 150, 150)
		Btn.Font = Enum.Font.Code
		Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)

		Btn.MouseButton1Click:Connect(function()
			AppState[key] = not AppState[key]
			Btn.BackgroundColor3 = AppState[key] and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(35, 35, 40)
			Btn.TextColor3 = AppState[key] and Color3.fromRGB(25, 25, 30) or Color3.fromRGB(150, 150, 150)
		end)
	end
	CreatePotionBtn("M", "M"); CreatePotionBtn("N", "N"); CreatePotionBtn("F", "F"); CreatePotionBtn("R", "R")

	-- Инпуты
	local function CreateInput(name, key, default, yPos)
		local Lbl = Instance.new("TextLabel", PropertiesPanel)
		Lbl.Size = UDim2.new(0, 60, 0, 20)
		Lbl.Position = UDim2.new(0, 15, 0, yPos)
		Lbl.BackgroundTransparency = 1
		Lbl.Text = name
		Lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
		Lbl.Font = Enum.Font.Code
		Lbl.TextSize = 12
		Lbl.TextXAlignment = Enum.TextXAlignment.Left

		local Box = Instance.new("TextBox", PropertiesPanel)
		Box.Size = UDim2.new(1, -100, 0, 25)
		Box.Position = UDim2.new(0, 85, 0, yPos - 2)
		Box.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		Box.TextColor3 = Color3.fromRGB(255, 255, 255)
		Box.Font = Enum.Font.Code
		Box.TextSize = 12
		Box.Text = default
		Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 4)

		Box:GetPropertyChangedSignal("Text"):Connect(function() AppState[key] = Box.Text end)
	end
	CreateInput("Name:", "RPName", "", 90)
	CreateInput("Age(1-6):", "Age", "6", 125)
	CreateInput("Friend:", "Friendship", "0", 160)

	-- Кнопка Спавна
	local SpawnBtn = Instance.new("TextButton", PropertiesPanel)
	SpawnBtn.Size = UDim2.new(1, -30, 0, 35)
	SpawnBtn.Position = UDim2.new(0, 15, 1, -50)
	SpawnBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
	SpawnBtn.Text = "Spawn Pet"
	SpawnBtn.Font = Enum.Font.Code
	SpawnBtn.TextSize = 14
	SpawnBtn.TextColor3 = Color3.fromRGB(25, 25, 30)
	Instance.new("UICorner", SpawnBtn).CornerRadius = UDim.new(0, 6)

	-- Внешнее API библиотеки
	local GUI_Obj = {
		Cards = {},
		OnSpawnClick = nil
	}

	SpawnBtn.MouseButton1Click:Connect(function()
		if GUI_Obj.OnSpawnClick and AppState.SelectedPetId then
			GUI_Obj.OnSpawnClick(AppState.SelectedPetId, AppState)
		end
	end)

	SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
		local q = string.lower(SearchBox.Text)
		for _, cardData in ipairs(GUI_Obj.Cards) do
			if q == "" or string.find(string.lower(cardData.Name), q) then
				cardData.UI.Visible = true
			else
				cardData.UI.Visible = false
			end
		end
	end)

	function GUI_Obj:CreateItem(id, name, imageId)
		local Card = Instance.new("TextButton")
		Card.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		Card.Text = ""
		Card.AutoButtonColor = false
		Card.Parent = ContentScroll
		Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 6)

		local UIScale = Instance.new("UIScale", Card)

		local TopLine = Instance.new("Frame", Card)
		TopLine.Size = UDim2.new(1, 0, 0, 2)
		TopLine.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TopLine.BorderSizePixel = 0
		local LineGrad = Instance.new("UIGradient", TopLine)
		LineGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 170, 0)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 80, 0))
		})

		local PetImage = Instance.new("ImageLabel", Card)
		PetImage.Size = UDim2.new(0.8, 0, 0.6, 0)
		PetImage.Position = UDim2.new(0.1, 0, 0.1, 0)
		PetImage.BackgroundTransparency = 1
		PetImage.ScaleType = Enum.ScaleType.Fit
		PetImage.Image = imageId or ""

		local PetName = Instance.new("TextLabel", Card)
		PetName.Size = UDim2.new(1, -10, 0, 20)
		PetName.Position = UDim2.new(0, 5, 1, -25)
		PetName.BackgroundTransparency = 1
		PetName.Text = name
		PetName.TextColor3 = Color3.fromRGB(200, 200, 200)
		PetName.Font = Enum.Font.Code
		PetName.TextSize = 12
		PetName.TextTruncate = Enum.TextTruncate.AtEnd

		Card.MouseEnter:Connect(function() TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.05}):Play() end)
		Card.MouseLeave:Connect(function() TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.0}):Play() end)

		Card.MouseButton1Click:Connect(function()
			AppState.SelectedPetId = id
			for _, c in ipairs(GUI_Obj.Cards) do c.UI.BackgroundColor3 = Color3.fromRGB(35, 35, 40) end
			Card.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
			PropTitle.Text = name
		end)

		table.insert(self.Cards, {UI = Card, Name = name, ID = id})
	end

	return GUI_Obj
end

return Library
