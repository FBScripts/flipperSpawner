		local TopLine = Instance.new("Frame", Card)
		TopLine.Size = UDim2.new(1, 0, 0, 2); TopLine.BackgroundColor3 = Color3.fromRGB(255, 255, 255); TopLine.BorderSizePixel = 0
		local LineGrad = Instance.new("UIGradient", TopLine)
		LineGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 170, 0)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 80, 0))})

		local PetImg = Instance.new("ImageLabel", Card)
		PetImg.Size = UDim2.new(0.8, 0, 0.6, 0); PetImg.Position = UDim2.new(0.1, 0, 0.1, 0); PetImg.BackgroundTransparency = 1; PetImg.ScaleType = Enum.ScaleType.Fit; PetImg.Image = imageId or ""

		local PetName = Instance.new("TextLabel", Card)
		PetName.Size = UDim2.new(1, -10, 0, 20); PetName.Position = UDim2.new(0, 5, 1, -25); PetName.BackgroundTransparency = 1; PetName.Text = name; PetName.TextColor3 = Color3.fromRGB(200, 200, 200); PetName.Font = Enum.Font.Code; PetName.TextSize = 12; PetName.TextTruncate = Enum.TextTruncate.AtEnd

		Card.MouseEnter:Connect(function() TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.05}):Play() end)
		Card.MouseLeave:Connect(function() TweenService:Create(UIScale, TWEEN_FAST, {Scale = 1.0}):Play() end)

		Card.MouseButton1Click:Connect(function()
			AppState.SelectedPetId = id
			for _, c in ipairs(GUI_Obj.Cards) do c.UI.BackgroundColor3 = Color3.fromRGB(35, 35, 40) end
			Card.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
			
			PropTitle.Text = name
			PropRarity.Text = "[" .. (rarity or "Common") .. "]"
			PreviewImg.Image = imageId or ""

			local rColor = Color3.fromRGB(150,150,150)
			local lr = tostring(rarity):lower()
			if lr == "legendary" then rColor = Color3.fromRGB(255, 215, 0)
			elseif lr == "ultra_rare" or lr == "ultra-rare" then rColor = Color3.fromRGB(255, 0, 150)
			elseif lr == "rare" then rColor = Color3.fromRGB(0, 150, 255)
			elseif lr == "uncommon" then rColor = Color3.fromRGB(0, 255, 100) end
			PropRarity.TextColor3 = rColor
		end)

		table.insert(self.Cards, {UI = Card, Name = name, ID = id})
	end

